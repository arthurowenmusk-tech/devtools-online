---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  wide?: boolean;
}

const { title, description, image, wide } = Astro.props;
const siteTitle = 'DevTools Online';
const siteDescription = description || 'Free online developer tools — JSON converter, diff checker, and more. No sign-up, no ads clutter. Just tools that work.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | {siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | ${siteTitle}`} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <style is:global>
      /* =============================================
         Clean Practical — For actual tool usage
         ============================================= */

      :root {
        --bg: #ffffff;
        --bg-surface: #f8f9fa;
        --bg-card: #ffffff;
        --bg-hover: #f0f2f5;
        --text: #1a1a2e;
        --text-secondary: #555770;
        --text-muted: #8e8ea0;
        --accent: #3b5ccc;
        --accent-hover: #2d4ab5;
        --accent-light: #eef1ff;
        --border: #e2e4e9;
        --border-light: #f0f1f3;
        --success: #10b981;
        --warning: #f59e0b;
        --radius-sm: 6px;
        --radius-md: 8px;
        --radius-lg: 12px;
        --max-width: 1200px;
        --max-width-narrow: 800px;
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
        --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        --font-mono: 'SF Mono', 'Fira Code', 'JetBrains Mono', 'Cascadia Code', Consolas, monospace;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
      }

      body {
        font-family: var(--font-sans);
        color: var(--text);
        background: var(--bg);
        line-height: 1.65;
        font-size: 15px;
        font-weight: 400;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* =============================================
         Header — clean & functional
         ============================================= */
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-light);
      }

      header nav {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 54px;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      header .logo {
        text-decoration: none;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--text);
        letter-spacing: -0.01em;
        transition: color 0.15s;
      }

      header .logo:hover { color: var(--accent); }

      header .nav-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      header .nav-links a {
        text-decoration: none;
        color: var(--text-secondary);
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 0.15s;
      }

      header .nav-links a:hover { color: var(--accent); }

      /* =============================================
         Main Content
         ============================================= */
      main {
        flex: 1;
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 4rem;
      }

      main.wide {
        max-width: 96vw;
        padding: 1rem 1.5rem 3rem;
      }

      /* =============================================
         Typography
         ============================================= */
      h1, h2, h3, h4, h5 {
        font-weight: 700;
        line-height: 1.3;
        color: var(--text);
        letter-spacing: -0.01em;
      }

      h1 { font-size: 1.75rem; margin: 0.5rem 0 0.75rem; }
      h2 { font-size: 1.35rem; margin: 2rem 0 0.75rem; }
      h3 { font-size: 1.1rem; margin: 1.25rem 0 0.5rem; }

      p { margin: 0.5rem 0; color: var(--text-secondary); line-height: 1.7; }

      a { color: var(--accent); text-decoration: none; transition: color 0.15s; }
      a:hover { color: var(--accent-hover); }

      ul, ol { margin: 0.5rem 0; padding-left: 1.5rem; color: var(--text-secondary); }
      li { margin: 0.3rem 0; }
      li strong { color: var(--text); }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 0.9rem;
      }

      th, td {
        border: 1px solid var(--border);
        padding: 0.6rem 0.9rem;
        text-align: left;
      }

      th {
        background: var(--bg-surface);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-secondary);
      }

      td { color: var(--text-secondary); }

      /* =============================================
         Callout
         ============================================= */
      .callout {
        background: var(--accent-light);
        border: 1px solid rgba(59,92,204,0.2);
        border-left: 3px solid var(--accent);
        padding: 0.9rem 1.2rem;
        margin: 1.5rem 0;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        font-size: 0.9rem;
        color: var(--text);
      }

      .callout strong { color: var(--accent); }

      /* =============================================
         Hero — practical, not flashy
         ============================================= */
      .hero {
        text-align: center;
        padding: 2.5rem 1rem 1.5rem;
      }

      .hero h1 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: var(--text);
        letter-spacing: -0.02em;
      }

      .hero p {
        font-size: 1.05rem;
        color: var(--text-secondary);
        max-width: 560px;
        margin: 0 auto;
      }

      /* =============================================
         Tool Grid & Cards — functional & clear
         ============================================= */
      .tool-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
        margin: 1.5rem 0 2.5rem;
      }

      .tool-card {
        display: block;
        text-decoration: none;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 1.25rem;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-shadow: var(--shadow-sm);
      }

      .tool-card:hover {
        border-color: var(--accent);
        box-shadow: var(--shadow-md);
      }

      .tool-card .icon {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
      }

      .tool-card h3 {
        margin: 0 0 0.35rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
      }

      .tool-card p {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin: 0 0 0.9rem;
        line-height: 1.5;
      }

      .tool-card .tag {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 600;
        color: var(--text-muted);
        background: var(--bg-surface);
        border: 1px solid var(--border);
        padding: 0.2rem 0.5rem;
        border-radius: var(--radius-sm);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      /* =============================================
         Buttons
         ============================================= */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--accent);
        color: #fff;
        border: none;
        padding: 0.5rem 1.1rem;
        border-radius: var(--radius-sm);
        font-family: var(--font-sans);
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: background 0.15s;
      }

      .btn:hover {
        background: var(--accent-hover);
        color: #fff;
        text-decoration: none;
      }

      .btn-secondary {
        background: var(--bg-surface);
        color: var(--text);
        border: 1px solid var(--border);
      }

      .btn-secondary:hover {
        background: var(--bg-hover);
        color: var(--text);
      }

      /* =============================================
         Dividers
         ============================================= */
      hr {
        border: none;
        height: 1px;
        background: var(--border-light);
        margin: 2rem 0;
      }

      /* =============================================
         Footer
         ============================================= */
      footer {
        border-top: 1px solid var(--border-light);
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
      }

      footer a {
        color: var(--text-muted);
        margin: 0 0.6rem;
        transition: color 0.15s;
      }

      footer a:hover { color: var(--accent); }

      footer p { margin: 0.35rem 0; font-size: 0.8rem; }

      /* =============================================
         Rating
         ============================================= */
      .rating { color: var(--warning); font-weight: 600; }

      /* =============================================
         Responsive
         ============================================= */
      @media (max-width: 768px) {
        h1 { font-size: 1.5rem; }
        h2 { font-size: 1.2rem; }
        .hero h1 { font-size: 1.6rem; }
        .hero { padding: 1.5rem 0.5rem 1rem; }
        header nav { padding: 0 1rem; height: 48px; }
        header .nav-links { gap: 1rem; }
        header .nav-links a { font-size: 0.8rem; }
        .tool-grid { grid-template-columns: 1fr; }
        main { padding: 1rem 1rem 3rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">{siteTitle}</a>
        <div class="nav-links">
          <a href="/json-tools">JSON</a>
          <a href="/diff-checker">Diff</a>
          <a href="/base64">Base64</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>
    <main class:list={[wide ? 'wide' : '']}>
      <slot />
    </main>
    <footer>
      <p>
        <a href="/privacy">Privacy</a> ·
        <a href="/terms">Terms</a> ·
        <a href="/about">About</a>
      </p>
      <p>&copy; {new Date().getFullYear()} DevTools Online</p>
    </footer>
  </body>
</html>
