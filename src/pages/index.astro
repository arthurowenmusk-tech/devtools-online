---
import Layout from '../layouts/Layout.astro';

const tools = [
  { icon: '🛠️', name: 'JSON Tools', href: '/json-tools', desc: 'Format, validate, minify. JSON↔CSV, YAML, TypeScript.', tag: 'Data' },
  { icon: '🔍', name: 'Diff Checker', href: '/diff-checker', desc: 'Compare two texts side by side. Line-by-line diff.', tag: 'Compare' },
  { icon: '🔐', name: 'Base64 & URL Encode', href: '/base64', desc: 'Encode/decode Base64 and URL strings.', tag: 'Encode' },
  { icon: '🔒', name: 'Hash Generator', href: '/hash-generator', desc: 'MD5, SHA-1, SHA-256, SHA-384, SHA-512.', tag: 'Crypto' },
  { icon: '🎲', name: 'UUID Generator', href: '/uuid-generator', desc: 'Generate UUID v4. Bulk generation supported.', tag: 'Generate' },
  { icon: '⏱️', name: 'Timestamp Converter', href: '/timestamp', desc: 'Unix timestamp ↔ human-readable date.', tag: 'Convert' },
  { icon: '🔐', name: 'JWT Decoder', href: '/jwt-decoder', desc: 'Decode and inspect JWT tokens. Check expiration.', tag: 'Debug' },
  { icon: '🎨', name: 'Color Converter', href: '/color-converter', desc: 'HEX ↔ RGB ↔ HSL. Live color picker.', tag: 'Convert' },
  { icon: '🔍', name: 'Regex Tester', href: '/regex-tester', desc: 'Test regular expressions with flags in real-time.', tag: 'Debug' },
  { icon: '⏰', name: 'Cron Parser', href: '/cron-parser', desc: 'Parse cron expressions. See next scheduled runs.', tag: 'DevOps' },
  { icon: '📝', name: 'Lorem Ipsum', href: '/lorem-ipsum', desc: 'Generate placeholder text for designs.', tag: 'Text' },
  { icon: '🔄', name: 'cURL to Code', href: '/curl-to-code', desc: 'Convert cURL commands to Python, JS, Go.', tag: 'Convert' },
];
---

<Layout
  title="Free Online Developer Tools"
  description="Free online developer tools — JSON, Base64, Hash, UUID, JWT, Diff Checker, and more. 100% client-side, no sign-up."
>
  <div class="hero">
    <h1>🛠️ Free Online Developer Tools</h1>
    <p>
      Simple, fast, private. Every tool runs in your browser — your data never leaves your device.
      No sign-up, no clutter. Just tools that work.
    </p>
  </div>

  <div class="callout">
    <strong>🔒 Privacy First</strong> — All processing happens locally in your browser.
    Your data is never uploaded to any server.
  </div>

  <h2>🧰 Tools ({tools.length})</h2>
  <div class="tool-grid">
    {tools.map(tool => (
      <div class="tool-card">
        <div class="icon">{tool.icon}</div>
        <h3><a href={tool.href}>{tool.name}</a></h3>
        <p>{tool.desc}</p>
        <span class="tag">{tool.tag}</span>
      </div>
    ))}
  </div>

  <hr />

  <h2>🚀 Why DevTools Online?</h2>
  <ul>
    <li>✅ <strong>100% Client-Side</strong> — Everything runs in your browser. No server, no uploads.</li>
    <li>✅ <strong>No Sign-Up</strong> — Just open a tool and use it.</li>
    <li>✅ <strong>Fast & Lightweight</strong> — No bloated frameworks. Pages load in under 1 second.</li>
  </ul>
</Layout>
