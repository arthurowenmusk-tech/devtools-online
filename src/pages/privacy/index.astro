import Layout from '../../layouts/Layout.astro';
---

<Layout title="Privacy Policy" description="Privacy Policy for DevTools Online.">
  <h1>Privacy Policy</h1>
  <p><em>Last updated: May 2026</em></p>

  <h2>1. Information We Collect</h2>
  <p>
    We use <strong>Google Analytics</strong> and <strong>Cloudflare Analytics</strong>
    to collect anonymized usage data, including pages visited, time on site, and
    referring URLs. We do not collect personal information unless you voluntarily
    contact us via email.
  </p>

  <h2>2. Cookies</h2>
  <p>
    We use minimal cookies for analytics purposes. You can disable cookies in your
    browser settings at any time.
  </p>

  <h2>3. Third-Party Services</h2>
  <p>
    This site may display advertisements via <strong>Google AdSense</strong>.
    Google may use cookies to serve personalized ads. You can opt out at
    <a href="https://adssettings.google.com">Google Ads Settings</a>.
  </p>

  <h2>4. Contact</h2>
  <p>
    For privacy questions, contact us at
    <a href="mailto:hello@YOUR-DOMAIN.com">hello@YOUR-DOMAIN.com</a>.
  </p>
</Layout>
